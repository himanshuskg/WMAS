@model IEnumerable<WMAS.Models.ViewModels.RoleAssignmentViewModel>
@using WMAS.Models

@{
    ViewData["Title"] = "Role Management";
    var departments = ViewBag.Departments as List<Department>;
    int? deptId = ViewBag.DepartmentId as int?;
    string roleFilter = ViewBag.RoleFilter as string ?? "";
}

<div class="container mt-3">

    <div class="card shadow-sm border-0 mb-2">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-1">
            <span class="small fw-semibold">
                <i class="bi bi-person-gear me-1"></i>Role Management (HR & Manager)
            </span>
        </div>
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Department</label>
                    <select name="departmentId" class="form-select form-select-sm">
                        <option value="">— All —</option>
                        @foreach (var d in departments!)
                        {
                            <option value="@d.DepartmentId"
                                    selected="@(deptId == d.DepartmentId)">
                                @d.DepartmentName
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Role Filter</label>
                    <select name="roleFilter" class="form-select form-select-sm">
                        <option value="" selected="@string.IsNullOrEmpty(roleFilter)">— All —</option>
                        <option value="HR" selected="@(roleFilter == "HR")">HR</option>
                        <option value="Manager" selected="@(roleFilter == "Manager")">Manager</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-person-dash fs-1"></i>
            <p class="mt-2 small">No employees found for the selected filters.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-primary small">
                        <tr>
                            <th>Employee</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th class="text-center">Active</th>
                            <th class="text-center">HR</th>
                            <th class="text-center">Manager</th>
                        </tr>
                    </thead>
                    <tbody class="small">
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@e.FullName</td>
                                <td>@e.Email</td>
                                <td>@(e.Department ?? "-")</td>
                                <td class="text-center">
                                    <span class="badge @(e.IsActive ? "bg-success" : "bg-secondary")">
                                        @(e.IsActive ? "Yes" : "No")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <form asp-action="UpdateRole" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="employeeId" value="@e.EmployeeId" />
                                        <input type="hidden" name="role" value="HR" />
                                        <input type="hidden" name="departmentId" value="@(deptId.HasValue? deptId.ToString() : "")" />
                                        <input type="hidden" name="roleFilter" value="@roleFilter" />
                                        <input type="hidden" name="isAssigned" value="@(e.IsHR ? "false" : "true")" />
                                        <button type="submit" class="btn btn-sm @(e.IsHR ? "btn-success" : "btn-outline-secondary")">
                                            @(e.IsHR ? "HR ✓" : "Assign")
                                        </button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <form asp-action="UpdateRole" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="employeeId" value="@e.EmployeeId" />
                                        <input type="hidden" name="role" value="Manager" />
                                        <input type="hidden" name="departmentId" value="@(deptId.HasValue? deptId.ToString() : "")" />
                                        <input type="hidden" name="roleFilter" value="@roleFilter" />
                                        <input type="hidden" name="isAssigned" value="@(e.IsManager ? "false" : "true")" />
                                        <button type="submit" class="btn btn-sm @(e.IsManager ? "btn-success" : "btn-outline-secondary")">
                                            @(e.IsManager ? "Mgr ✓" : "Assign")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>