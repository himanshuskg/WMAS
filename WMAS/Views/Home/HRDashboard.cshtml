@{
    ViewData["Title"] = "HR Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-people-gear me-2"></i>HR Dashboard
        </h4>
        <small class="text-muted">
            @DateTime.Today.ToString("dddd, dd MMMM yyyy")
        </small>
    </div>
    <span class="badge bg-info fs-6 px-3 py-2">HR</span>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-people-fill fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TotalEmployees</div>
                    <div class="text-muted small">Total Employees</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Employee" asp-action="Index"
                       class="btn btn-sm btn-outline-primary w-100">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-info bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-person-check-fill fs-3 text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TodayPresent</div>
                    <div class="text-muted small">Present Today</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Attendance" asp-action="AdminIndex"
                       class="btn btn-sm btn-outline-info w-100">
                    Attendance <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-hourglass-split fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.PendingLeaves</div>
                    <div class="text-muted small">Pending Leaves</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="LeaveApproval" asp-action="Index"
                       class="btn btn-sm btn-outline-warning w-100">
                    Review Leaves <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-cash-stack fs-3 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">
                        @ViewBag.SalariesFinalized
                        <span class="fs-6 text-muted fw-normal">
                            / @ViewBag.SalariesGenerated
                        </span>
                    </div>
                    <div class="text-muted small">
                        Salaries Finalized
                        <span class="d-block">
                            @DateTime.Today.ToString("MMMM yyyy")
                        </span>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Salary" asp-action="Index"
                       class="btn btn-sm btn-outline-success w-100">
                    Payroll <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-bottom">
        <span class="fw-semibold">
            <i class="bi bi-lightning-charge me-2 text-warning"></i>Quick Actions
        </span>
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-6 col-md-3">
                <a asp-controller="Attendance" asp-action="AdminIndex"
                       class="btn btn-outline-info w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-calendar-check fs-4"></i>
                    <small>View Attendance</small>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="LeaveApproval" asp-action="Index"
                       class="btn btn-outline-warning w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-clipboard2-check fs-4"></i>
                    <small>Leave Requests</small>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Salary" asp-action="Index"
                       class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-cash-stack fs-4"></i>
                    <small>Generate Payroll</small>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Report" asp-action="Index"
                       class="btn btn-outline-secondary w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-bar-chart-line fs-4"></i>
                    <small>Reports</small>
                </a>
            </div>
        </div>
    </div>
</div>