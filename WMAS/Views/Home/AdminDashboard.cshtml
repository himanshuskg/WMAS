<h2>Admin Dashboard</h2>

<div class="row mt-4">

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>Total Employees</h5>
                <h3>@ViewBag.TotalEmployees</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>Active Employees</h5>
                <h3>@ViewBag.ActiveEmployees</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5>Pending Leaves</h5>
                <h3>@ViewBag.PendingLeaves</h3>
            </div>
        </div>
    </div>

</div>
