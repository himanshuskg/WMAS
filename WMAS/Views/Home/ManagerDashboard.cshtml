@using WMAS.Models
@{
    ViewData["Title"] = "Manager Dashboard";
}
@{
    var todayAtt = ViewBag.TodayAtt as Attendance;

    string statusText = "Not Checked In";
    string statusClass = "bg-secondary";

    if (todayAtt != null && todayAtt.CheckOutTime == null)
    {
        statusText = "Logged In";
        statusClass = "bg-success";
    }
    else if (todayAtt != null && todayAtt.CheckOutTime != null)
    {
        statusText = "Logged Out";
        statusClass = "bg-primary";
    }
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-person-badge me-2"></i>Manager Dashboard
        </h4>
        <small class="text-muted">
            @DateTime.Today.ToString("dddd, dd MMMM yyyy")
        </small>
    </div>
    <div class="d-flex gap-2">
        <span class="badge bg-warning text-dark fs-6 px-3 py-2">Manager</span>
        <span class="badge @statusClass fs-6 px-3 py-2">@statusText</span>
    </div>
</div>
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">

        <div>
            <h6 class="fw-semibold mb-1">
                <i class="bi bi-clock me-2 text-primary"></i>Your Attendance
            </h6>

            @if (todayAtt == null)
            {
                <span class="text-muted">Not checked in today</span>
            }
            else if (todayAtt.CheckOutTime == null)
            {
                <span class="text-success">
                    Checked in at @todayAtt.CheckInTime?.ToString("hh:mm tt")
                </span>
            }
            else
            {
                var duration = (todayAtt.CheckOutTime ?? DateTime.Now) - (todayAtt.CheckInTime ?? DateTime.Now);

                <span class="text-primary">
                    Completed • @((int)duration.TotalHours)h @duration.Minutes m
                </span>
            }
        </div>

        <div>
            @if (todayAtt == null)
            {
                <small class="text-muted d-block mt-1">
                    Click "Check In" to start your day
                </small>
                <form asp-controller="Attendance" asp-action="CheckIn" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-success">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Check In
                    </button>
                </form>
            }
            else if (todayAtt.CheckOutTime == null)
            {
                <form asp-controller="Attendance" asp-action="CheckOut" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-danger">
                        <i class="bi bi-box-arrow-right me-1"></i>Check Out
                    </button>
                </form>
            }
            else
            {
                <span class="badge bg-success px-3 py-2">
                    <i class="bi bi-check-circle me-1"></i>Completed
                </span>
            }
        </div>

    </div>
</div>
<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-people-fill fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TeamCount</div>
                    <div class="text-muted small">Team Members</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Attendance" asp-action="ManagerIndex"
                       class="btn btn-sm btn-outline-primary w-100">
                    View Team <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-person-check-fill fs-3 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TeamPresent</div>
                    <div class="text-muted small">Present Today</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Attendance" asp-action="ManagerIndex"
                       class="btn btn-sm btn-outline-success w-100">
                    Attendance <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-info bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-calendar2-check fs-3 text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.TeamOnLeave</div>
                    <div class="text-muted small">On Leave Today</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="LeaveApproval" asp-action="Index"
                       class="btn btn-sm btn-outline-info w-100">
                    Leave Records <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-hourglass-split fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.PendingLeaves</div>
                    <div class="text-muted small">Pending Approvals</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="LeaveApproval" asp-action="Index"
                       class="btn btn-sm btn-outline-warning w-100">
                    Review <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-bottom">
        <span class="fw-semibold">
            <i class="bi bi-lightning-charge me-2 text-warning"></i>Quick Actions
        </span>
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-6 col-md-6">
                <a asp-controller="Attendance" asp-action="ManagerIndex"
                       class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-calendar-check fs-4"></i>
                    <small>Team Attendance</small>
                </a>
            </div>
            <div class="col-6 col-md-6">
                <a asp-controller="LeaveApproval" asp-action="Index"
                       class="btn btn-outline-warning w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-clipboard2-check fs-4"></i>
                    <small>Team Leave Approvals</small>
                </a>
            </div>
        </div>
    </div>
</div>