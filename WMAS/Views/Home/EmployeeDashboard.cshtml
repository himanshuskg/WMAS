@using WMAS.Models
@{
    ViewData["Title"] = "Dashboard";
    var attendance = ViewBag.Attendance as Attendance;
    var notes = ViewBag.Notes as List<Note>;
}

@if (ViewBag.ShowPasswordWarning == true)
{
    <div class="alert alert-warning alert-dismissible fade show persistent-alert shadow-sm">
        <i class="bi bi-shield-exclamation me-2"></i>
        You are using a system-generated password. Please
        <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="alert-link">
            change your password
        </a> now.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold"><i class="bi bi-speedometer2 me-2"></i>My Dashboard</h4>
        <small class="text-muted">@DateTime.Today.ToString("dddd, dd MMMM yyyy")</small>
    </div>
</div>

<div class="row g-3">

    <!-- ── Attendance Card ──────────────────────────────── -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-clock me-2 text-primary"></i>Today's Attendance</span>
                <a asp-controller="Attendance" asp-action="MyAttendance"
                       class="btn btn-sm btn-outline-primary">
                    History <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body">

                @if (attendance == null)
                {
                    <p class="text-muted mb-3">You haven't checked in yet today.</p>
                    <form asp-controller="Attendance" asp-action="CheckIn" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Check In
                        </button>
                    </form>
                }
                else
                {
                    <div class="d-flex gap-4 mb-3">
                        <div>
                            <div class="text-muted small">Checked In</div>
                            <div class="fw-semibold fs-5 text-success">
                                @attendance.CheckInTime?.ToString("hh:mm tt")
                            </div>
                        </div>

                        @if (attendance.CheckOutTime != null)
                        {
                            var total = attendance.CheckOutTime.Value - attendance.CheckInTime!.Value;
                            <div>
                                <div class="text-muted small">Checked Out</div>
                                <div class="fw-semibold fs-5 text-danger">
                                    @attendance.CheckOutTime?.ToString("hh:mm tt")
                                </div>
                            </div>
                            <div>
                                <div class="text-muted small">Total Hours</div>
                                <div class="fw-semibold fs-5">@total.ToString(@"hh\:mm")</div>
                            </div>
                        }
                        else
                        {
                            var elapsed = DateTime.Now - attendance.CheckInTime!.Value;
                            <div>
                                <div class="text-muted small">Elapsed</div>
                                <div class="fw-semibold fs-5 text-warning">
                                    @elapsed.ToString(@"hh\:mm")
                                </div>
                            </div>
                        }
                    </div>

                    @if (attendance.CheckOutTime == null)
                    {
                        <form asp-controller="Attendance" asp-action="CheckOut" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-box-arrow-right me-2"></i>Check Out
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6">
                            <i class="bi bi-check-circle me-1"></i>Day Complete
                        </span>
                    }
                }

            </div>
        </div>
    </div>

    <!-- ── Quick Links Card ─────────────────────────────── -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom">
                <span class="fw-semibold">
                    <i class="bi bi-lightning-charge me-2 text-warning"></i>Quick Actions
                </span>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6">
                        <a asp-controller="Leave" asp-action="Apply"
                               class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center gap-1">
                            <i class="bi bi-calendar-plus fs-4"></i>
                            <small>Apply Leave</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Leave" asp-action="Index"
                               class="btn btn-outline-secondary w-100 py-3 d-flex flex-column align-items-center gap-1">
                            <i class="bi bi-list-check fs-4"></i>
                            <small>My Leaves</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Attendance" asp-action="MyAttendance"
                               class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center gap-1">
                            <i class="bi bi-calendar-check fs-4"></i>
                            <small>Attendance</small>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="LeaveApproval" asp-action="Index"
                               class="btn btn-outline-info w-100 py-3 d-flex flex-column align-items-center gap-1">
                            <i class="bi bi-people fs-4"></i>
                            <small>Team Approvals</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Notes Card ───────────────────────────────────── -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom">
                <span class="fw-semibold">
                    <i class="bi bi-sticky me-2 text-warning"></i>My Notes
                </span>
            </div>
            <div class="card-body">
                <form asp-action="AddNote" method="post" class="mb-3 d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <textarea name="content" class="form-control" rows="2"
                              placeholder="Write something to remember..."
                              maxlength="500"></textarea>
                    <button type="submit" class="btn btn-primary align-self-end">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </form>

                @if (notes != null && notes.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var note in notes)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start px-0">
                                <span>@note.Content</span>
                                <a asp-action="DeleteNote" asp-route-id="@note.NoteId"
                                       class="btn btn-sm btn-link text-danger p-0 ms-2"
                                       title="Delete">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small mb-0">No notes yet.</p>
                }
            </div>
        </div>
    </div>

</div>
