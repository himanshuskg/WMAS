@using WMAS.Models
@{
    ViewData["Title"] = "My Dashboard";
    var employee = ViewBag.Employee as Employee;
    var todayAtt = ViewBag.TodayAtt as Attendance;
    var latestSalary = ViewBag.LatestSalary as Salary;
    var notes = ViewBag.Notes as List<Note>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-person-circle me-2"></i>
            Welcome, @(employee?.FullName ?? "Employee")
        </h4>
        <small class="text-muted">
            @DateTime.Today.ToString("dddd, dd MMMM yyyy")
            @if (employee?.Department != null)
            {
                <span class="ms-2 badge bg-secondary">
                    @employee.Department.DepartmentName
                </span>
            }
            @if (employee?.Designation != null)
            {
                <span class="ms-1 badge bg-light text-dark border">
                    @employee.Designation.Title
                </span>
            }
        </small>
    </div>@{
    string statusText = "Not Checked In";
    string statusClass = "bg-secondary";

    if (todayAtt != null && todayAtt.CheckOutTime == null)
    {
        statusText = "Logged In";
        statusClass = "bg-success";
    }
    else if (todayAtt != null && todayAtt.CheckOutTime != null)
    {
        statusText = "Logged Out";
        statusClass = "bg-primary";
    }
}

<div class="d-flex gap-2">
    <span class="badge bg-secondary fs-6 px-3 py-2">Employee</span>
    <span class="badge @statusClass fs-6 px-3 py-2">@statusText</span>
</div>
</div>

<!-- Today's Attendance Status -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h6 class="fw-semibold mb-3">
                    <i class="bi bi-clock me-2 text-primary"></i>Today's Status
                </h6>
                @if (todayAtt == null)
                {
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-dash-circle fs-3 text-secondary"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-secondary">Not Checked In</div>
                            <small class="text-muted">
                                You haven't checked in today
                            </small>
                        </div>
                    </div>
                }
                else if (todayAtt.CheckOutTime == null)
                {
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-box-arrow-in-right fs-3 text-success"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-success">Checked In</div>
                            <small class="text-muted">
                                Since @todayAtt.CheckInTime?.ToString("hh:mm tt")
                            </small>
                        </div>
                    </div>
                }
                else
                {
                    var duration = (todayAtt.CheckOutTime ?? DateTime.Now) - (todayAtt.CheckInTime ?? DateTime.Now);
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-check-circle fs-3 text-primary"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-primary">Completed</div>
                            <small class="text-muted">
                                @todayAtt.CheckInTime?.ToString("hh:mm tt")
                                →
                                @todayAtt.CheckOutTime?.ToString("hh:mm tt")
                                &nbsp;|&nbsp;
                                @((int)duration.TotalHours)h @duration.Minutes m worked
                            </small>
                        </div>
                    </div>
                }
            </div>

            <!-- CheckIn / CheckOut buttons -->
            <div class="col-md-6 mt-3 mt-md-0 text-md-end">
                @if (todayAtt == null)
                {
                    <small class="text-muted d-block mt-1">
                        Click "Check In" to start your day
                    </small>
                    <form asp-controller="Attendance" asp-action="CheckIn" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-success px-4">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Check In
                        </button>
                    </form>
                }
                else if (todayAtt.CheckOutTime == null)
                {
                    <form asp-controller="Attendance" asp-action="CheckOut"
                          method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-danger px-4">
                            <i class="bi bi-box-arrow-right me-2"></i>Check Out
                        </button>
                    </form>
                }
                else
                {
                    <span class="badge bg-success px-3 py-2 fs-6">
                        <i class="bi bi-check-circle me-1"></i>Day Complete
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-calendar2-check fs-3 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.UsedLeaves</div>
                    <div class="text-muted small">
                        Leaves Used in @DateTime.Today.Year
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Leave" asp-action="Index"
                       class="btn btn-sm btn-outline-success w-100">
                    My Leaves <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-hourglass-split fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@ViewBag.PendingLeaves</div>
                    <div class="text-muted small">Pending Leave Requests</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Leave" asp-action="Apply"
                       class="btn btn-sm btn-outline-warning w-100">
                    Apply Leave <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-cash-stack fs-3 text-primary"></i>
                </div>
                <div>
                    @if (latestSalary != null)
                    {
                        <div class="fs-4 fw-bold">
                            ₹@latestSalary.NetSalary.ToString("N0")
                        </div>
                        <div class="text-muted small">
                            Last Salary —
                            @(new DateTime(latestSalary.Year,
                                latestSalary.Month, 1).ToString("MMM yyyy"))
                        </div>
                    }
                    else
                    {
                        <div class="fs-5 fw-bold text-muted">—</div>
                        <div class="text-muted small">No salary yet</div>
                    }
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-controller="Salary" asp-action="MySlips"
                       class="btn btn-sm btn-outline-primary w-100">
                    My Salary <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-bottom">
        <span class="fw-semibold">
            <i class="bi bi-lightning-charge me-2 text-warning"></i>Quick Actions
        </span>
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-6 col-md-4">
                <a asp-controller="Attendance" asp-action="MyAttendance"
                       class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-calendar-check fs-4"></i>
                    <small>My Attendance</small>
                </a>
            </div>
            <div class="col-6 col-md-4">
                <a asp-controller="Leave" asp-action="Apply"
                       class="btn btn-outline-warning w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-calendar-plus fs-4"></i>
                    <small>Apply Leave</small>
                </a>
            </div>
            <div class="col-6 col-md-4">
                <a asp-controller="Salary" asp-action="MySlips"
                       class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center gap-1">
                    <i class="bi bi-receipt fs-4"></i>
                    <small>Salary Slips</small>
                </a>
            </div>
        </div>
    </div>
</div>
<div class="col-12 mb-4">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-bottom">
            <span class="fw-semibold">
                <i class="bi bi-sticky me-2 text-warning"></i>My Notes
            </span>
        </div>
        <div class="card-body">
            <form asp-controller="Home" asp-action="AddNote" method="post" class="mb-3 d-flex gap-2">
                @Html.AntiForgeryToken()
                <textarea name="content" class="form-control" rows="2"
                          placeholder="Write something to remember..."
                          maxlength="500"></textarea>
                <button type="submit" class="btn btn-primary align-self-end">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </form>

            @if (notes != null && notes.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var note in notes)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start px-0">
                            <span>@note.Content</span>
                            <a asp-controller="Home" asp-action="DeleteNote" asp-route-id="@note.NoteId" class="btn btn-sm btn-link text-danger p-0 ms-2" title="Delete">
                                <i class="bi bi-trash3"></i>
                            </a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted small mb-0">No notes yet.</p>
            }
        </div>
    </div>
</div>