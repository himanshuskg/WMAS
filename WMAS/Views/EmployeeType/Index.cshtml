@model IEnumerable<WMAS.Models.EmployeeType>

@{
    ViewData["Title"] = "Employee Types";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-tag me-2"></i>Employee Types
    </h4>
</div>

<!-- Add New -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent border-bottom">
        <span class="fw-semibold small">
            <i class="bi bi-plus-circle me-1 text-success"></i>Add New Type
        </span>
    </div>
    <div class="card-body py-3">
        <form asp-action="Create" method="post"
              class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-md-6">
                <input type="text" name="name"
                       class="form-control"
                       placeholder="e.g. Full Time, Part Time, Contract..."
                       maxlength="100" required />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-plus-lg me-1"></i>Add
                </button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-tag fs-1"></i>
        <p class="mt-2">No employee types yet. Add one above.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-primary small">
                    <tr>
                        <th>#</th>
                        <th>Type Name</th>
                        <th class="text-center" style="width:280px">Actions</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @{
                        int sr = 1;
                    }
                    @foreach (var type in Model)
                    {
                        <tr>
                            <td class="text-muted">@sr</td>
                            <td>
                                <!-- Inline edit -->
                                <form asp-action="Edit" method="post"
                                      class="d-flex gap-2 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id"
                                           value="@type.Id" />
                                    <input type="text" name="name"
                                           value="@type.Name"
                                           class="form-control form-control-sm"
                                           style="max-width:250px"
                                           maxlength="100" required />
                                    <button type="submit"
                                            class="btn btn-outline-primary btn-sm"
                                            title="Save">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="text-center">
                                <form asp-action="Delete" method="post"
                                      class="d-inline"
                                      onsubmit="return confirm(
                                    'Delete \'@type.Name\'?\nThis cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id"
                                           value="@type.Id" />
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm"
                                            title="Delete">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        sr++;
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-transparent small text-muted">
            @Model.Count() type(s) total
        </div>
    </div>
}