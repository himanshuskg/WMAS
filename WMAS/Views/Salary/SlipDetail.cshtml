@model WMAS.Models.Salary
@using WMAS.Models

@{
    ViewData["Title"] = "Salary Slip";
    var emp         = Model.Employee;
    var monthLabel  = new DateTime(Model.Year, Model.Month, 1)
                          .ToString("MMMM yyyy");
    decimal perDay  = Model.WorkingDays > 0
                          ? Model.BasicPay / Model.WorkingDays
                          : 0;
}

<!-- Print / Back buttons — hidden on print -->
<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <a asp-action="MySlips" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
        {
            <a asp-action="Index" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-list me-1"></i>Payroll List
            </a>
        }
        <button onclick="window.print()"
                class="btn btn-primary btn-sm">
            <i class="bi bi-printer me-1"></i>Print / Download
        </button>
    </div>
</div>

<!-- ── SLIP CARD ─────────────────────────────────── -->
<div class="card border shadow-sm mx-auto" style="max-width:750px;"
     id="salarySlip">

    <!-- Header -->
    <div class="card-header bg-primary text-white text-center py-3">
        <h5 class="mb-0 fw-bold">WMAS — Salary Slip</h5>
        <div class="small opacity-75">@monthLabel</div>
        @if (Model.IsFinalized)
        {
            <span class="badge bg-success mt-1">Finalized</span>
        }
        else
        {
            <span class="badge bg-warning text-dark mt-1">Draft</span>
        }
    </div>

    <div class="card-body px-4 py-3">

        <!-- Employee details -->
        <div class="row mb-3">
            <div class="col-6">
                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted fw-semibold">Employee</td>
                        <td>: @emp?.FullName</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Employee ID</td>
                        <td>: EMP-@emp?.EmployeeId.ToString("D4")</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Department</td>
                        <td>: @(emp?.Department?.DepartmentName ?? "—")</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Designation</td>
                        <td>: @(emp?.Designation?.Title ?? "—")</td>
                    </tr>
                </table>
            </div>
            <div class="col-6">
                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted fw-semibold">Pay Period</td>
                        <td>: @monthLabel</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Working Days</td>
                        <td>: @Model.WorkingDays (Mon–Sat)</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Per Day Rate</td>
                        <td>: ₹@perDay.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-semibold">Joining Date</td>
                        <td>
                            : @(emp?.JoiningDate.ToString("dd MMM yyyy") ?? "—")
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <hr />

        <!-- Attendance breakdown -->
        <h6 class="fw-semibold text-secondary mb-2">
            <i class="bi bi-calendar-check me-1"></i>Attendance Breakdown
        </h6>
        <div class="row g-2 mb-3">
            <div class="col-6 col-md-3">
                <div class="border rounded text-center py-2">
                    <div class="fs-5 fw-bold text-success">
                        @Model.PresentDays
                    </div>
                    <div class="text-muted small">Full Days</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="border rounded text-center py-2">
                    <div class="fs-5 fw-bold text-warning">
                        @Model.HalfDays
                    </div>
                    <div class="text-muted small">Half Days</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="border rounded text-center py-2">
                    <div class="fs-5 fw-bold text-info">
                        @Model.ApprovedLeave
                    </div>
                    <div class="text-muted small">Approved Leave</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="border rounded text-center py-2">
                    <div class="fs-5 fw-bold text-danger">
                        @Model.LopDaysExact.ToString("0.##")
                    </div>
                    <div class="text-muted small">LOP Days</div>
                </div>
            </div>
        </div>

        <hr />

        <!-- Earnings & Deductions -->
        <div class="row">
            <!-- Earnings -->
            <div class="col-md-6 mb-3">
                <h6 class="fw-semibold text-success mb-2">
                    <i class="bi bi-plus-circle me-1"></i>Earnings
                </h6>
                <table class="table table-sm mb-0 small">
                    <tbody>
                        <tr>
                            <td>Basic Pay</td>
                            <td class="text-end">₹@Model.BasicPay.ToString("N2")</td>
                        </tr>
                        @if (Model.Allowances > 0)
                        {
                            <tr>
                                <td>Allowances</td>
                                <td class="text-end text-success">
                                    +₹@Model.Allowances.ToString("N2")
                                </td>
                            </tr>
                        }
                        <tr class="fw-bold border-top">
                            <td>Gross Earnings</td>
                            <td class="text-end text-success">
                                ₹@((Model.BasicPay + Model.Allowances).ToString("N2"))
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Deductions -->
            <div class="col-md-6 mb-3">
                <h6 class="fw-semibold text-danger mb-2">
                    <i class="bi bi-dash-circle me-1"></i>Deductions
                </h6>
                <table class="table table-sm mb-0 small">
                    <tbody>
                        @if (Model.LopDaysExact > 0)
                        {
                            <tr>
                                <td>
                                    LOP (@Model.LopDaysExact.ToString("0.##")
                                    days × ₹@perDay.ToString("N2"))
                                </td>
                                <td class="text-end text-danger">
                                    -₹@((perDay * (decimal)Model.LopDaysExact)
                                        .ToString("N2"))
                                </td>
                            </tr>
                        }
                        @if (Model.Deductions > 0)
                        {
                            <tr>
                                <td>Other Deductions</td>
                                <td class="text-end text-danger">
                                    -₹@Model.Deductions.ToString("N2")
                                </td>
                            </tr>
                        }
                        @if (Model.LopDaysExact == 0 && Model.Deductions == 0)
                        {
                            <tr>
                                <td colspan="2" class="text-muted text-center">
                                    No deductions
                                </td>
                            </tr>
                        }
                        <tr class="fw-bold border-top">
                            <td>Total Deductions</td>
                            <td class="text-end text-danger">
                                ₹@Model.Deductions.ToString("N2")
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <hr />

        <!-- Net Salary -->
        <div class="d-flex justify-content-between align-items-center
                    bg-primary bg-opacity-10 rounded p-3">
            <div>
                <div class="fw-bold fs-5">Net Salary Payable</div>
                <div class="text-muted small">
                    @monthLabel
                </div>
            </div>
            <div class="fs-2 fw-bold text-primary">
                ₹@Model.NetSalary.ToString("N2")
            </div>
        </div>

        @if (!Model.IsFinalized)
        {
            <div class="alert alert-warning mt-3 mb-0 small py-2 d-print-none">
                <i class="bi bi-exclamation-triangle me-1"></i>
                <strong>Draft</strong> — This slip has not been finalized yet.
                Amounts may change.
            </div>
        }
    </div>

    <!-- Footer -->
    <div class="card-footer bg-transparent text-center small text-muted py-2">
        Generated by WMAS &nbsp;|&nbsp;
        @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")
        &nbsp;|&nbsp; This is a computer-generated slip.
    </div>
</div>

<!-- Print styles -->
<style>
    @@media print {
        body * { visibility: hidden; }
        #salarySlip, #salarySlip * { visibility: visible; }
        #salarySlip {
            position: absolute;
            left: 0; top: 0;
            width: 100%;
            box-shadow: none !important;
            border: none !important;
        }
    }
</style>