@model IEnumerable<WMAS.Models.Salary>
@using WMAS.Models

@{
    ViewData["Title"] = "My Salary Slips";
    int year = ViewBag.Year != null ? (int)ViewBag.Year : DateTime.Today.Year;
    var employee = ViewBag.Employee as Employee;
}

<div class="container mt-3">
    <div class="card shadow-sm border-0 mb-2">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-1">
            <span class="small fw-semibold">
                <i class="bi bi-receipt me-1"></i>My Salary Slips — @year
            </span>
            <form method="get" class="d-flex gap-2 align-items-center">
                <select name="year" class="form-select form-select-sm"
                        style="width:90px" onchange="this.form.submit()">
                    @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 3; y--)
                    {
                        <option value="@y" selected="@(y == year)">@y</option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-receipt fs-1"></i>
            <p class="mt-2 small">No salary records found for @year.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-primary small">
                        <tr>
                            <th>Month</th>
                            <th class="text-end">Basic Pay</th>
                            <th class="text-end">Allowances</th>
                            <th class="text-end">Deductions</th>
                            <th class="text-end">Net Salary</th>
                        </tr>
                    </thead>
                    <tbody class="small">
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    @(new DateTime(s.Year, s.Month, 1).ToString("MMMM yyyy"))
                                </td>
                                <td class="text-end">₹@s.BasicPay.ToString("N2")</td>
                                <td class="text-end text-success">+₹@s.Allowances.ToString("N2")</td>
                                <td class="text-end text-danger">-₹@s.Deductions.ToString("N2")</td>
                                <td class="text-end fw-bold text-primary">
                                    ₹@s.NetSalary.ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light small fw-semibold">
                        <tr>
                            <td>Annual Total (@Model.Count() months)</td>
                            <td class="text-end">₹@Model.Sum(s => s.BasicPay).ToString("N2")</td>
                            <td></td>
                            <td></td>
                            <td class="text-end text-success">
                                ₹@Model.Sum(s => s.NetSalary).ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>
