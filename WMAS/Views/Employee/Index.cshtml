@model WMAS.Models.ViewModels.EmployeeListViewModel

@{
    ViewData["Title"] = "Employees";
}

<style>
    /* 🔹 Compact UI */
    .card-body {
        padding: 8px 10px !important;
    }

    .form-label {
        font-size: 12px;
        margin-bottom: 2px;
    }

    .form-control,
    .form-select {
        height: 30px;
        font-size: 12px;
    }

    .s2-checkbox {
        /* pointer-events: none; */ /* ← Remove or comment this line */
        cursor: pointer; /* Nice to have */
    }

    /* 🔹 Select2 Fixes */
    .select2-container .select2-selection--multiple {
        min-height: 30px !important;
        max-height: 30px !important;
        overflow: hidden !important;
        font-size: 12px;
        padding: 2px 6px;
    }

    /* ❌ REMOVE TAG STACKING */
    .select2-container--default .select2-selection__choice {
        display: none !important;
    }

    /* 🔹 Dropdown Scroll */
    .select2-results__options {
        max-height: 200px;
        overflow-y: auto;
    }

    .select2-results__option {
        font-size: 12px;
        padding: 4px 8px;
    }
</style>

<div class="container mt-3">

    <!-- 🔹 FILTER SECTION -->
    <div class="card shadow-sm border-0 mb-2">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-1">
            <span class="small fw-semibold">Employee List</span>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-light btn-sm">+ Add</a>            
            }
        </div>

        <div class="card-body">
            <form method="get" asp-action="Index" id="filterForm">

                <div class="row g-2 align-items-end">

                    <!-- 🔹 Search -->
                    <div class="col-md-2">
                        <label class="form-label">Search</label>
                        <input asp-for="SearchTerm" class="form-control" placeholder="Name..." />
                    </div>

                    <!-- 🔹 Department -->
                    <div class="col-md-2">
                        <label class="form-label">Department</label>
                        <select asp-for="SelectedDepartmentIds"
                                asp-items="@(new MultiSelectList(Model.Departments, "DepartmentId", "DepartmentName", Model.SelectedDepartmentIds))"
                                id="departmentsMultiselect"
                                multiple
                                class="form-select"></select>
                    </div>

                    <!-- 🔹 Type -->
                    <div class="col-md-2">
                        <label class="form-label">Type</label>
                        <select asp-for="SelectedEmployeeTypeIds"
                                asp-items="@(new MultiSelectList(Model.EmployeeTypes, "Id", "Name", Model.SelectedEmployeeTypeIds))"
                                id="employeeTypesMultiselect"
                                multiple
                                class="form-select"></select>
                    </div>

                    <!-- 🔹 Designation -->
                    <div class="col-md-2">
                        <label class="form-label">Designation</label>
                        <select asp-for="SelectedDesignationIds"
                                asp-items="@(new MultiSelectList(Model.Designations, "DesignationId", "Title", Model.SelectedDesignationIds))"
                                id="designationMultiselect"
                                multiple
                                class="form-select"></select>
                    </div>

                    <!-- 🔹 Apply -->
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-success btn-sm w-100 py-1">
                            Apply
                        </button>
                    </div>

                    <!-- 🔹 Clear -->
                    <div class="col-md-1">
                        <button type="button" onclick="clearFilters()" class="btn btn-outline-secondary btn-sm w-100 py-1">
                            Clear
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- 🔹 TABLE -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">

                <thead class="table-primary small">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody class="small">
                    @if (!Model.Employees?.Any() ?? true)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">
                                No data
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var e in Model.Employees)
                        {
                            <tr>
                                <td>@e.FullName</td>
                                <td>@e.Email</td>
                                <td>@e.Department?.DepartmentName</td>
                                <td>@e.Designation?.Title</td>
                                <td>@e.EmployeeType?.Name</td>

                                <td>
                                    <span class="badge @(e.IsActive ? "bg-success" : "bg-secondary") small">
                                        @(e.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>

                                <td class="text-end">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@e.EmployeeId" class="btn btn-outline-primary btn-sm">Edit</a>
                                    }
                                    <a asp-action="Details" asp-route-id="@e.EmployeeId" class="btn btn-outline-secondary btn-sm">View</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>

    <!-- 🔹 PAGINATION -->
    <div class="d-flex justify-content-between align-items-center mt-2 small">

        <!-- 🔹 Rows -->
        <div class="d-flex align-items-center gap-1">
            <span>Rows:</span>
            <select asp-for="PageSize"
                    asp-items="@(new SelectList(Model.PageSizeOptions))"
                    class="form-select form-select-sm"
                    style="width:65px"
                    onchange="this.form.submit();">
            </select>
        </div>

        <!-- 🔹 Pagination -->
        <nav aria-label="Employee List Pagination">
            <ul class="pagination pagination-sm mb-0">

                @if (Model.PageNumber == 1)
                {
                    <li class="page-item disabled"><span class="page-link">«</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", GetRouteValues(Model.PageNumber - 1))">«</a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", GetRouteValues(i))">@i</a>
                    </li>
                }

                @if (Model.PageNumber == Model.TotalPages)
                {
                    <li class="page-item disabled"><span class="page-link">»</span></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", GetRouteValues(Model.PageNumber + 1))">»</a>
                    </li>
                }

            </ul>
        </nav>

        <!-- 🔹 Page Info -->
        <div>
            <span>@Model.PageNumber / @Model.TotalPages</span>
        </div>

    </div>

</div>

@functions {
    private object GetRouteValues(int page)
    {
        return new
        {
            searchTerm = Model.SearchTerm,
            SelectedDepartmentIds = Model.SelectedDepartmentIds,
            SelectedDesignationIds = Model.SelectedDesignationIds,
            SelectedEmployeeTypeIds = Model.SelectedEmployeeTypeIds,
            pageSize = Model.PageSize,
            pageNumber = page
        };
    }
}

@section Scripts {
    <script>
        $(document).ready(function () {
            const selectors = '#departmentsMultiselect, #employeeTypesMultiselect, #designationMultiselect';

            // Template: Use data.selected for accuracy
            function formatOption(data) {
                if (!data.id) return data.text;

                const isChecked = data.selected ? 'checked' : '';
                return $(
                    '<div class="d-flex align-items-center">' +
                    '  <input type="checkbox" class="s2-checkbox me-2" ' + isChecked + ' />' +
                    '  <span>' + data.text + '</span>' +
                    '</div>'
                );
            }

            // Init
            $(selectors).select2({
                placeholder: "Select",
                closeOnSelect: false,
                width: '100%',
                templateResult: formatOption,
                templateSelection: function() { return "Select"; },
                escapeMarkup: function(m) { return m; }
            });

            // Update "X selected" text
            function updateSummary($select) {
                const count = ($select.val() || []).length;
                $select.next('.select2-container')
                       .find('.select2-selection__rendered')
                       .text(count > 0 ? count + " selected" : "Select");
            }

            // Checkbox click drives selection
            $(document).on('click', '.s2-checkbox', function (e) {
                e.stopPropagation();
                e.preventDefault();

                const $option = $(this).closest('.select2-results__option');
                const data = $option.data('data');
                if (!data) return;

                const $select = $(this).closest('.select2').prev('select');

                if (this.checked) {
                    $select.trigger('select', { data: data });
                } else {
                    $select.trigger('unselect', { data: data });
                }
            });

            // After any change: update summary + force visual sync by re-rendering dropdown
            $(selectors).on('select2:select select2:unselect change', function (e) {
                const $this = $(this);
                updateSummary($this);

                // Force re-render checkboxes (brief close/open - no flicker noticed)
                if ($this.data('select2').isOpen()) {
                    setTimeout(() => {
                        $this.select2('close');
                        setTimeout(() => $this.select2('open'), 0);
                    }, 0);
                }
            });

            // Initial summary for pre-selected (from query string)
            $(selectors).each(function () {
                updateSummary($(this));
            });
        });

        // Clear filters
        function clearFilters() {
            $('#SearchTerm').val('');
            const selectors = '#departmentsMultiselect, #employeeTypesMultiselect, #designationMultiselect';
            $('#filterForm')[0].reset();
            $(selectors).val(null).trigger('change');
            $('#filterForm').submit();
        }
    </script>
}