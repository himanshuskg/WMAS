@model IEnumerable<WMAS.Models.Department>

<div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Departments</h2>

        <a asp-action="Create" class="btn btn-outline-primary">+ Add Department</a>
    </div>

    <!-- Table -->
    <div class="card">
        <div class="card-body p-0">

            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70%;">Department Name</th>
                        <th style="width: 30%;" class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4">
                                No departments found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.DepartmentName</td>

                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.DepartmentId"
                                        class="btn btn-sm btn-outline-secondary me-1"> Edit</a>
                                    @if (item.IsActive)
                                    {
                                        <button class="btn btn-warning btn-sm" onclick="openConfirmAction(
                                                                {
                                                                    title: 'Deactivate Department', 
                                                                    message: 'Are you sure you want to deactivate this department?',
                                                                    buttonText: 'Deactivate', 
                                                                    controller: 'Department', 
                                                                    action: 'Deactivate', 
                                                                    id: @item.DepartmentId
                                                                })">
                                            Deactivate
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success btn-sm" onclick="openConfirmAction(
                                                                {
                                                                    title: 'Activate Department',
                                                                    message: 'This Department will reactivate.',
                                                                    buttonText: 'Activate',
                                                                    controller: 'Department',
                                                                    action: 'Activate',
                                                                    id: @item.DepartmentId
                                                                })">
                                            Activate
                                        </button>

                                    }

                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>